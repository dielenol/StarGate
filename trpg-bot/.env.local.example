# 로컬 개발용 Discord Application/Bot 값을 넣으세요.
# 운영 다채봇 토큰을 넣지 않습니다.
DISCORD_TOKEN=your_dev_bot_token_here
DISCORD_CLIENT_ID=your_dev_client_id_here

# 로컬 테스트 서버 ID. 길드 명령으로 즉시 등록되도록 둘 다 같은 값을 권장합니다.
GUILD_ID=your_dev_guild_id_here
TRPG_GUILD_ID=your_dev_guild_id_here

# 주사위 명령만 실제 Discord에서 테스트할 때는 1로 둡니다.
# 이 모드에서는 MongoDB 연결, 멤버 동기화, 세션 알림/리마인드 폴링을 실행하지 않습니다.
TRPG_BOT_DICE_ONLY=1

# TRPG_BOT_DICE_ONLY=0 으로 /세션확인까지 테스트할 때만 아래 값을 채웁니다.
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/stargate?retryWrites=true&w=majority
MONGODB_DB_NAME=stargate_local
# TRPG_FALLBACK_CHANNEL_ID=your_dev_fallback_text_channel_id_here
# TRPG_WEB_BASE_URL=http://localhost:3000

# 로컬에서는 알림 폴링이 자주 돌지 않게 기본보다 길게 둡니다.
TRPG_POLLING_INTERVAL_MS=3600000
TRPG_REMINDER_INTERVAL_MS=3600000
RESULT_CARD_IMAGE=0
