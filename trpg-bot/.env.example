# Discord Bot Token (Discord Developer Portal > Applications > Bot)
DISCORD_TOKEN=your_bot_token_here

# Discord Application (Client) ID
DISCORD_CLIENT_ID=your_client_id_here

# MongoDB Atlas connection string
# trpg-web과 같은 stargate 통합 DB를 바라보게 설정
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/stargate?retryWrites=true&w=majority
# MONGODB_DB_NAME=stargate

# /세션확인 슬래시 커맨드를 특정 길드에만 등록할 때 사용
# 운영에서는 전역 반영 대기/잔존 커맨드 혼선을 줄이기 위해 TRPG_GUILD_ID와 같은 값 권장
GUILD_ID=your_trpg_guild_id_here

# trpg-bot 운영 길드 ID (필수)
TRPG_GUILD_ID=your_trpg_guild_id_here

# DM 실패 시 같은 내용을 멘션으로 보내는 폴백 텍스트 채널 ID (필수)
TRPG_FALLBACK_CHANNEL_ID=your_fallback_text_channel_id_here

# trpg-web 운영 URL (필수)
TRPG_WEB_BASE_URL=https://dache-calender.vercel.app

# trpg-web 세션 생성/수정/취소 알림 폴링 주기(ms). 기본 60000
# TRPG_POLLING_INTERVAL_MS=60000

# 24시간 전 리마인드 폴링 주기(ms). 기본 300000
# TRPG_REMINDER_INTERVAL_MS=300000

# /세션확인 캘린더 PNG 렌더링(Puppeteer). 끄려면 0 / false / off
# RESULT_CARD_IMAGE=1
