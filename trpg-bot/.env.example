# Discord Bot Token (Discord Developer Portal > Applications > Bot)
DISCORD_TOKEN=your_bot_token_here

# Discord Application (Client) ID
DISCORD_CLIENT_ID=your_client_id_here

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/trpg_bot?retryWrites=true&w=majority

# 개발용: 슬래시 커맨드를 특정 길드에만 등록할 때 사용 (선택)
# GUILD_ID=your_guild_id_here
