{
  "name": "stargatev2",
  "version": "1.0.0",
  "description": "Stargate TRPG 공식 랜딩 웹앱 - 세계관 소개, 프로젝트 소식, 이메일 문의 및 지원 접수",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm --filter @stargate/shared-db build && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "optimize:images": "node scripts/optimize-public-images.mjs",
    "db:ensure-indexes": "pnpm --filter @stargate/shared-db build && node --experimental-strip-types scripts/ensure-indexes.ts",
    "preseed:factions": "pnpm --filter @stargate/shared-db build",
    "seed:factions": "node --experimental-strip-types scripts/seed-factions.ts",
    "preseed:institutions": "pnpm --filter @stargate/shared-db build",
    "seed:institutions": "node --experimental-strip-types scripts/seed-institutions.ts",
    "preseed:shop": "pnpm --filter @stargate/shared-db build",
    "seed:shop": "node --experimental-strip-types scripts/seed-shop-catalog.ts",
    "preseed:stocks": "pnpm --filter @stargate/shared-db build",
    "seed:stocks": "node --experimental-strip-types scripts/seed-stock-catalog.ts",
    "preseed:stock-history": "pnpm --filter @stargate/shared-db build",
    "seed:stock-history": "node --experimental-strip-types scripts/seed-stock-history.ts",
    "seed:payload": "node --experimental-strip-types scripts/upsert-seed-payload.ts",
    "premigrate:character-sheet": "pnpm --filter @stargate/shared-db build",
    "migrate:character-sheet": "node --experimental-strip-types scripts/migrate-character-sheet-to-lore-play.ts",
    "premigrate:credit-balances": "pnpm --filter @stargate/shared-db build",
    "migrate:credit-balances": "node --experimental-strip-types scripts/migrate-credit-balances.ts",
    "migrate:character-equipment": "node --experimental-strip-types scripts/migrate-character-equipment-to-inventory.ts"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "keywords": [
    "nextjs",
    "landing-page",
    "stargate",
    "trpg"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@stargate/shared-db": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "bcryptjs": "^3.0.3",
    "diff-match-patch": "^1.0.5",
    "mongodb": "^7.1.1",
    "next": "^16.1.6",
    "next-auth": "5.0.0-beta.30",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  }
}
