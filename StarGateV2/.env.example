DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
# Optional: 서브패스 배포 시에만 설정 (예: /StarGate)
NEXT_PUBLIC_APP_BASE_PATH=
# Optional: 메타 절대 URL 고정 (예: https://novus-ordo.vercel.app)
NEXT_PUBLIC_SITE_URL=

# --- Auth & ERP ---
# Auth.js secret (openssl rand -base64 32 로 생성)
AUTH_SECRET=
# Production URL for Auth.js redirects (예: https://novus-ordo.vercel.app)
AUTH_URL=
# StarGate V2 Discord OAuth (https://discord.com/developers/applications)
STARGATE_DISCORD_CLIENT_ID=
STARGATE_DISCORD_CLIENT_SECRET=
# Legacy local fallback only. Vercel에서는 STARGATE_* 사용 권장.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# MongoDB Atlas (기존 registra-bot과 동일 클러스터)
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Discord 서버(길드) ID — 세션 캘린더 등에서 사용
GUILD_ID=

# --- Stock market ---
# Optional: 0/false/off 로 설정하면 매수·매도만 중지하고 시세 조회는 유지
STOCK_MARKET_ENABLED=1
# Vercel Cron Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=
# Scheduled stock market Discord webhook (server-only)
DISCORD_WEBHOOK_STOCK_URL=
# Daily shop restock Discord webhook (server-only)
DISCORD_WEBHOOK_SHOP_URL=
# Character edit and GM admin audit Discord webhook (server-only)
DISCORD_WEBHOOK_CHAR_EDIT_URL=
# Optional legacy fallback for player self-edit alerts.
# Prefer DISCORD_WEBHOOK_CHAR_EDIT_URL so admin/player edit alerts land in one audit channel.
DISCORD_WEBHOOK_CHAR_SELF_EDIT_URL=
# Equipment research event Discord webhook (server-only)
DISCORD_WEBHOOK_RESEARCH_URL=
# Optional: GM 공방 결과 이미지 업로드. 미설정 시 HTTPS URL 또는 /assets 경로 직접 입력만 사용합니다.
BLOB_READ_WRITE_TOKEN=
