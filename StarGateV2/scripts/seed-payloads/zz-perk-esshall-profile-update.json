            "MAKEHUMANGREATAGAIN",
            "NOSB-MINI-S1E1-NEW-DUBLIN",
            "MINI-S1E1"
          ],
          "appearsInEvents": [
            "NOSB-MINI-S1E1-NEW-DUBLIN"
