{
  "name": "trpg-web",
  "version": "0.1.0",
  "description": "StarGate TRPG 세션 캘린더 웹앱 — Discord OAuth + 월간 캘린더 + 세션 생성/편집",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm --filter @stargate/shared-db build && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test --experimental-strip-types tests/**/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@stargate/shared-db": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "mongodb": "^7.1.1",
    "next": "^16.1.6",
    "next-auth": "5.0.0-beta.30",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "typescript": "^5.9.3"
  }
}
