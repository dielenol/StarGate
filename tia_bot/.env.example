# tia_bot environment variables
# 실제 운영에서는 이 파일을 복사해 .env 로 만든 뒤 값 채움. .env 는 git ignore.

# Discord Bot Token
DISCORD_TOKEN=

# OpenAI / Copilot API
COPILOT_API_KEY=

# MongoDB 연결
# StarGateV2 와 동일 클러스터/DB 사용 (stargate)
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=stargate

# 작전 크레딧 풀 식별자 (변경 비권장)
TIA_BOT_DEFAULT_OP_POOL_ID=OPERATION
