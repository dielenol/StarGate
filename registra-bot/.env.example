# Discord Bot Token (Discord Developer Portal > Applications > Bot)
DISCORD_TOKEN=your_bot_token_here

# Discord Application (Client) ID
DISCORD_CLIENT_ID=your_client_id_here

# MongoDB Atlas connection string
# DB 이름은 연결 URI 경로와 맞추거나 MONGODB_DB_NAME으로 지정 (기본: registrar_bot)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/registrar_bot?retryWrites=true&w=majority
# MONGODB_DB_NAME=registrar_bot

# 개발용: 슬래시 커맨드를 특정 길드에만 등록할 때 사용 (선택)
# GUILD_ID=your_guild_id_here

# 마감 시 결과 카드 PNG 첨부 (Puppeteer). 끄려면 0 / false / off
# RESULT_CARD_IMAGE=0

# `/일정 참여확인` 월간 캘린더 PNG 재첨부 간격(분). 0이면 매번 시도(전역 PNG 큐·간격으로 부하 완화)
# PARTICIPATION_CHECK_IMAGE_COOLDOWN_MINUTES=30

# Puppeteer PNG 직렬화 후 최소 대기(ms). 연속 렌더 스파이크 완화
# PNG_RENDER_MIN_INTERVAL_MS=500
